# =============================================================================
# .gitignore for MyFirstPipeline
# =============================================================================

# --- Raw sequence data (too large for GitHub, ~100MB limit) ---
*.fq.gz
*.fastq.gz
*.fq
*.fastq

# --- Pipeline output directories (generated by the pipeline, not source code) ---
pipeline_output/
fastqc/
bam/
counts/
means/
fold_changes/
logs/
bowtie2_index/

# --- Genome and annotation files (already on the server, no need to track) ---
*.fa
*.fasta
*.bed

# --- BAM/SAM alignment files ---
*.bam
*.bai
*.sam

# --- SLURM output/error logs (generated at runtime) ---
slurm-*.out
slurm-*.err
*.slurm.log

# --- Temporary files ---
*.tmp
*.temp
*_tmp.txt
*_temp.txt

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Python/R (just in case) ---
__pycache__/
*.pyc
.Rhistory
.RData

# --- Editor files ---
*.swp
*.swo
*~
.vscode/
.idea/
